{
  "name": "hoodies-ui",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "bun run build:stores && /Users/jmal/projects/stacksjs/stx/bin/stx dev",
    "build": "bun run build:stores && bun run --bun stx build",
    "build:stores": "bun run lib/build.ts",
    "preview": "bun run --bun stx preview",
    "lint": "bunx --bun pickier .",
    "lint:fix": "bunx --bun pickier . --fix",
    "format": "bunx --bun pickier . --format",
    "format:fix": "bunx --bun pickier . --format --write",
    "postinstall": "bunx git-hooks"
  },
  "dependencies": {
    "@cwcss/crosswind": "^0.1.6",
    "ts-syntax-highlighter": "^0.2.1"
  },
  "devDependencies": {
    "@stacksjs/stx": "^0.2.6",
    "bun-plugin-stx": "^0.2.6",
    "typescript": "^5.0.0",
    "bun-git-hooks": "^0.3.1"
  },
  "git-hooks": {
    "pre-commit": {
      "staged-lint": {
        "*.{js,ts,json,yaml,yml,md}": "bunx --bun pickier lint --fix"
      }
    }
  }
}
