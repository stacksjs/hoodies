      <!-- 06 - Lorem ipsum (card) -->
      <div class="relative flex items-start pl-4 md:pl-4">
        <!-- Timeline dot -->
        <div class="relative z-2 flex-shrink-0 w-8.5 h-8.5 rounded-full roadmap-dot-inactive flex items-center justify-center -ml-4">
          <svg width="16" height="11" viewBox="0 0 16 11" fill="none" class="text-accent opacity-40">
            <path d="M1 5L6 10L15 1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <!-- Content card -->
        <div class="flex-1 pl-8 md:pl-16 -mt-1">
          <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-2 md:gap-8 mb-6">
            <span class="font-sora text-base tracking-[0.05em] text-accent">06</span>
            <span class="font-sora text-sm tracking-[0.02em] text-[#b3b3b3] whitespace-nowrap">December 2022</span>
          </div>
          <div class="bg-white rounded-[30px] px-6 md:px-12 py-7 md:py-8 roadmap-card-shadow">
            <h3 class="font-sora font-semibold text-lg md:text-[22px] leading-7 text-dark mb-3">Lorem ipsum</h3>
            <p class="font-sora font-normal text-sm md:text-base leading-7 text-muted">
              Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip.
            </p>
          </div>
        </div>
